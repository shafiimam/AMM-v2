      "blocks": {
        "richtext_9dG8gD": {
          "type": "richtext",
          "settings": {
            "content": "<h1>Maniere Noir Demi-Sec Rosé</h1>",
            "text_color": "#e49d9d"
          }
        },
        "richtext_jfLmwr": {
          "type": "richtext",
          "settings": {
            "content": "<p>Crafted in the heart of the Champagne region, Maniere Noir Demi-Sec Rosé is a delightful expression of indulgent elegance. As a \"Demi-Sec,\" it possesses a noticeable sweetness, perfectly balanced by a refreshing acidity that makes it both rich and lively. This Champagne is designed for pleasure, offering a more generous and fruit-forward profile making it an approachable yet sophisticated choice for celebrations and decadent pairings.</p>",
            "text_color": "#535353"
          }
        },
        "button_drEBmM": {
