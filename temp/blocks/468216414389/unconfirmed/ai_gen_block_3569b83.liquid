{% doc %}
  @prompt
    Create a landing page section modeled after a Stories section with a grid layout for story cards, each featuring an image, headline, and brief description, with customizable settings for layout, colors, and content
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-stories-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-stories-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-stories-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-stories-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    text-transform: {{ block.settings.heading_text_transform }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}%;
  }

  .ai-stories-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-stories-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_top_spacing }}px;
  }

  .ai-story-card-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-story-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.card_hover_lift }}px);
    box-shadow: 0 {{ block.settings.card_hover_lift | times: 2 }}px {{ block.settings.card_hover_lift | times: 4 }}px rgba(0, 0, 0, 0.1);
  }

  .ai-story-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-story-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-story-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-story-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-story-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-story-headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.card_heading_font.family }}, {{ block.settings.card_heading_font.fallback_families }};
    font-weight: {{ block.settings.card_heading_font.weight }};
    font-size: {{ block.settings.card_heading_size }}px;
    color: {{ block.settings.card_heading_color }};
    margin: 0 0 {{ block.settings.card_text_spacing }}px;
    text-transform: {{ block.settings.card_heading_text_transform }};
  }

  .ai-story-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_size }}px;
    color: {{ block.settings.card_description_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.card_text_spacing }}px;
    flex-grow: 1;
  }

  .ai-story-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.card_link_size }}px;
    color: {{ block.settings.card_link_color }};
    text-decoration: none;
    font-weight: 500;
    margin-top: auto;
    transition: color 0.3s ease;
  }

  .ai-story-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.card_link_hover_color }};
  }

  .ai-story-link-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-story-link-{{ ai_gen_id }}:hover .ai-story-link-arrow-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  @media screen and (max-width: 989px) {
    .ai-stories-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }

    .ai-stories-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-story-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_heading_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-stories-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 0 {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-stories-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-stories-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-story-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_heading_size | times: 0.85 }}px;
    }

    .ai-story-content-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<stories-section-{{ ai_gen_id }} class="ai-stories-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-stories-container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank or block.settings.section_subheading != blank %}
      <div class="ai-stories-header-{{ ai_gen_id }}">
        {% if block.settings.section_heading != blank %}
          <h2 class="ai-stories-title-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
        {% endif %}
        {% if block.settings.section_subheading != blank %}
          <div class="ai-stories-subtitle-{{ ai_gen_id }}">{{ block.settings.section_subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-stories-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign story_enabled_key = 'story_' | append: i | append: '_enabled'
          assign story_image_key = 'story_' | append: i | append: '_image'
          assign story_headline_key = 'story_' | append: i | append: '_headline'
          assign story_description_key = 'story_' | append: i | append: '_description'
          assign story_link_text_key = 'story_' | append: i | append: '_link_text'
          assign story_link_url_key = 'story_' | append: i | append: '_link_url'

          assign story_enabled = block.settings[story_enabled_key]
          assign story_image = block.settings[story_image_key]
          assign story_headline = block.settings[story_headline_key]
          assign story_description = block.settings[story_description_key]
          assign story_link_text = block.settings[story_link_text_key]
          assign story_link_url = block.settings[story_link_url_key]
        %}

        {% if story_enabled %}
          <div class="ai-story-card-{{ ai_gen_id }}">
            <div class="ai-story-image-wrapper-{{ ai_gen_id }}">
              {% if story_image %}
                <img
                  src="{{ story_image | image_url: width: 800 }}"
                  alt="{{ story_image.alt | escape }}"
                  loading="lazy"
                  width="{{ story_image.width }}"
                  height="{{ story_image.height }}"
                  class="ai-story-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-story-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-story-content-{{ ai_gen_id }}">
              {% if story_headline != blank %}
                <h3 class="ai-story-headline-{{ ai_gen_id }}">{{ story_headline }}</h3>
              {% endif %}

              {% if story_description != blank %}
                <div class="ai-story-description-{{ ai_gen_id }}">{{ story_description }}</div>
              {% endif %}

              {% if story_link_text != blank and story_link_url != blank %}
                <a href="{{ story_link_url }}" class="ai-story-link-{{ ai_gen_id }}">
                  {{ story_link_text }}
                  <svg class="ai-story-link-arrow-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</stories-section-{{ ai_gen_id }}>

<script>
  (function() {
    class StoriesSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-story-card-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.cards.forEach((card) => {
          const link = card.querySelector('.ai-story-link-{{ ai_gen_id }}');
          if (link) {
            card.setAttribute('role', 'article');
          }
        });
      }
    }

    customElements.define('stories-section-{{ ai_gen_id }}', StoriesSection{{ ai_gen_id }});
  })();
</script>

