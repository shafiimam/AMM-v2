{% doc %}
  @prompt
    I would like to create a page layout similar to the following: https://www.veuveclicquot.com/en-us/veuve-clicquot-la-grande-dame-limited-edition-2018-by-simon-porte-jacquemus-10969623.html
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-product-hero-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    min-height: {{ block.settings.min_height_mobile }}vh;
    background-color: {{ block.settings.background_color }};
    position: relative;
  }

  @media screen and (min-width: 750px) {
    .ai-luxury-product-hero-{{ ai_gen_id }} {
      grid-template-columns: {% if block.settings.layout == 'image_left' %}1fr 1fr{% else %}1fr 1fr{% endif %};
      min-height: {{ block.settings.min_height_desktop }}vh;
    }
  }

  .ai-luxury-product-hero__image-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    {% if block.settings.layout == 'image_right' %}
      order: 2;
    {% endif %}
  }

  .ai-luxury-product-hero__image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ block.settings.image_position }};
  }

  .ai-luxury-product-hero__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-luxury-product-hero__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-luxury-product-hero__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-luxury-product-hero__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: {{ block.settings.content_padding_mobile }}px;
    color: {{ block.settings.text_color }};
    {% if block.settings.layout == 'image_right' %}
      order: 1;
    {% endif %}
  }

  @media screen and (min-width: 750px) {
    .ai-luxury-product-hero__content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_desktop }}px;
    }
  }

  .ai-luxury-product-hero__content-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    {% if block.settings.content_alignment == 'left' %}
      margin-right: auto;
    {% elsif block.settings.content_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    {% else %}
      margin-left: auto;
      text-align: right;
    {% endif %}
  }

  .ai-luxury-product-hero__eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}px;
    text-transform: {{ block.settings.eyebrow_transform }};
    margin-bottom: {{ block.settings.eyebrow_spacing }}px;
    opacity: 0.8;
  }

  .ai-luxury-product-hero__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_mobile }}px;
    line-height: {{ block.settings.title_line_height }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    text-transform: {{ block.settings.title_transform }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: {{ block.settings.title_weight }};
  }

  @media screen and (min-width: 750px) {
    .ai-luxury-product-hero__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_desktop }}px;
    }
  }

  .ai-luxury-product-hero__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    line-height: 1.6;
    margin-bottom: {{ block.settings.subtitle_spacing }}px;
    opacity: 0.9;
  }

  .ai-luxury-product-hero__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.8;
    margin-bottom: {{ block.settings.description_spacing }}px;
    opacity: 0.85;
  }

  .ai-luxury-product-hero__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: {{ block.settings.price_weight }};
    margin-bottom: {{ block.settings.price_spacing }}px;
    letter-spacing: 1px;
  }

  .ai-luxury-product-hero__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-top: {{ block.settings.button_spacing }}px;
    {% if block.settings.content_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.content_alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-product-hero__buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }

  .ai-luxury-product-hero__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.primary_btn_bg }};
    color: {{ block.settings.primary_btn_text }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.primary_btn_border }};
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
    text-transform: {{ block.settings.button_transform }};
    transition: all 0.3s ease;
    cursor: pointer;
    font-weight: {{ block.settings.button_weight }};
  }

  .ai-luxury-product-hero__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_btn_bg_hover }};
    color: {{ block.settings.primary_btn_text_hover }};
    border-color: {{ block.settings.primary_btn_border_hover }};
  }

  .ai-luxury-product-hero__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_btn_bg }};
    color: {{ block.settings.secondary_btn_text }};
    border-color: {{ block.settings.secondary_btn_border }};
  }

  .ai-luxury-product-hero__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_btn_bg_hover }};
    color: {{ block.settings.secondary_btn_text_hover }};
    border-color: {{ block.settings.secondary_btn_border_hover }};
  }

  .ai-luxury-product-hero__features-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: {{ block.settings.features_spacing }}px;
    font-size: {{ block.settings.features_size }}px;
  }

  .ai-luxury-product-hero__feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    {% if block.settings.content_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.content_alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-luxury-product-hero__feature-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-luxury-product-hero__feature-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
  }
{% endstyle %}

<div class="ai-luxury-product-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-product-hero__image-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
      >
    {% else %}
      <div class="ai-luxury-product-hero__image-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-luxury-product-hero__empty-state-{{ ai_gen_id }}">
          Add an image to showcase your product
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-luxury-product-hero__content-{{ ai_gen_id }}">
    <div class="ai-luxury-product-hero__content-inner-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <div class="ai-luxury-product-hero__eyebrow-{{ ai_gen_id }}">
          {{ block.settings.eyebrow }}
        </div>
      {% endif %}

      {% if block.settings.title != blank %}
        <h1 class="ai-luxury-product-hero__title-{{ ai_gen_id }}">
          {{ block.settings.title }}
        </h1>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <div class="ai-luxury-product-hero__subtitle-{{ ai_gen_id }}">
          {{ block.settings.subtitle }}
        </div>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-luxury-product-hero__description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      {% if block.settings.show_price and block.settings.price_text != blank %}
        <div class="ai-luxury-product-hero__price-{{ ai_gen_id }}">
          {{ block.settings.price_text }}
        </div>
      {% endif %}

      {% if block.settings.show_features %}
        <div class="ai-luxury-product-hero__features-{{ ai_gen_id }}">
          {% if block.settings.feature_1 != blank %}
            <div class="ai-luxury-product-hero__feature-{{ ai_gen_id }}">
              <div class="ai-luxury-product-hero__feature-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span>{{ block.settings.feature_1 }}</span>
            </div>
          {% endif %}

          {% if block.settings.feature_2 != blank %}
            <div class="ai-luxury-product-hero__feature-{{ ai_gen_id }}">
              <div class="ai-luxury-product-hero__feature-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span>{{ block.settings.feature_2 }}</span>
            </div>
          {% endif %}

          {% if block.settings.feature_3 != blank %}
            <div class="ai-luxury-product-hero__feature-{{ ai_gen_id }}">
              <div class="ai-luxury-product-hero__feature-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span>{{ block.settings.feature_3 }}</span>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_buttons %}
        <div class="ai-luxury-product-hero__buttons-{{ ai_gen_id }}">
          {% if block.settings.primary_btn_label != blank %}
            <a
              href="{{ block.settings.primary_btn_link }}"
              class="ai-luxury-product-hero__button-{{ ai_gen_id }}"
            >
              {{ block.settings.primary_btn_label }}
            </a>
          {% endif %}

          {% if block.settings.secondary_btn_label != blank %}
            <a
              href="{{ block.settings.secondary_btn_link }}"
              class="ai-luxury-product-hero__button-{{ ai_gen_id }} ai-luxury-product-hero__button--secondary-{{ ai_gen_id }}"
            >
              {{ block.settings.secondary_btn_label }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

