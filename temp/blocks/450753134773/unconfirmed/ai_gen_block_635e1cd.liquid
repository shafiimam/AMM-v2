{% doc %}
  @prompt
    Create an image card grid of four across (4-column layout) optimized for model photography.
    Each card should display:
    
    Image at the top (full-width, responsive, model-scale ratio — e.g., 3:4 or 4:5).
    
    Product details below the image: product name, price, and a “Shop the Look” button.
    
    The “Shop the Look” button should open a quick-add or modal view allowing users to add multiple products from the look directly to cart (e.g., jacket, shirt, pants, shoes).
    
    Design specs:
    
    Maintain equal spacing and consistent padding between cards.
    
    Cards should stack to two across on tablet and one across on mobile.
    
    Clean typography with minimal overlays — the focus is on the model imagery.
    
    Include hover states for desktop (e.g., light image zoom or button reveal).
    
    Goal:
    
    A visually cohesive, shoppable grid that blends editorial presentation with e-commerce functionality — enabling the customer to experience the look and purchase it seamlessly., I would also like the ability to change the button to a link 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-model-grid-{{ ai_gen_id }} {
    width: 100%;
    padding: 0;
  }

  .ai-model-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.card_spacing }}px;
    width: 100%;
  }

  .ai-model-card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
  }

  .ai-model-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-model-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  {% if block.settings.enable_image_zoom %}
    .ai-model-card-{{ ai_gen_id }}:hover .ai-model-card__image-{{ ai_gen_id }} {
      transform: scale(1.05);
    }
  {% endif %}

  .ai-model-card__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-model-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-model-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
  }

  .ai-model-card__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.3;
    color: {{ block.settings.text_color }};
    margin: 0;
    text-transform: {{ block.settings.title_transform }};
    letter-spacing: 0.02em;
  }

  .ai-model-card__price-{{ ai_gen_id }} {
    font-family: {{ block.settings.price_font.family }}, {{ block.settings.price_font.fallback_families }};
    font-weight: {{ block.settings.price_font.weight }};
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-model-card__button-{{ ai_gen_id }},
  .ai-model-card__link-{{ ai_gen_id }} {
    margin-top: auto;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_size }}px;
    text-transform: {{ block.settings.button_transform }};
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    text-decoration: none;
    display: block;
    width: 100%;
  }

  .ai-model-card__button-{{ ai_gen_id }}:hover,
  .ai-model-card__link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-model-modal-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
    z-index: 9999;
    overflow-y: auto;
    padding: 20px;
  }

  .ai-model-modal-{{ ai_gen_id }}.active {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-model-modal__content-{{ ai_gen_id }} {
    background-color: {{ block.settings.modal_background }};
    max-width: 900px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    border-radius: {{ block.settings.modal_border_radius }}px;
    padding: 40px;
  }

  .ai-model-modal__close-{{ ai_gen_id }} {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    z-index: 1;
  }

  .ai-model-modal__close-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-model-modal__header-{{ ai_gen_id }} {
    margin-bottom: 30px;
  }

  .ai-model-modal__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: 24px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px 0;
    text-transform: {{ block.settings.title_transform }};
  }

  .ai-model-modal__subtitle-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
  }

  .ai-model-modal__products-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 30px;
  }

  .ai-model-modal__product-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 20px;
    align-items: center;
    padding: 20px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 8px;
  }

  .ai-model-modal__product-image-{{ ai_gen_id }} {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 4px;
  }

  .ai-model-modal__product-image-placeholder-{{ ai_gen_id }} {
    width: 100px;
    height: 100px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-model-modal__product-image-placeholder-{{ ai_gen_id }} svg {
    width: 50px;
    height: 50px;
    opacity: 0.3;
  }

  .ai-model-modal__product-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-model-modal__product-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: 16px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-model-modal__product-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-model-modal__product-variant-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
  }

  .ai-model-modal__product-select-{{ ai_gen_id }} {
    padding: 8px 12px;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 4px;
    font-size: 14px;
    background-color: #ffffff;
    cursor: pointer;
  }

  .ai-model-modal__add-button-{{ ai_gen_id }} {
    padding: 16px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_size }}px;
    text-transform: {{ block.settings.button_transform }};
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
  }

  .ai-model-modal__add-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-model-modal__add-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-model-modal__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  @media screen and (max-width: 989px) {
    .ai-model-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.card_spacing | times: 0.75 }}px;
    }

    .ai-model-card__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-model-card__price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size | times: 0.9 }}px;
    }

    .ai-model-modal__content-{{ ai_gen_id }} {
      padding: 30px 20px;
    }

    .ai-model-modal__product-{{ ai_gen_id }} {
      grid-template-columns: 80px 1fr;
      gap: 15px;
    }

    .ai-model-modal__product-image-{{ ai_gen_id }},
    .ai-model-modal__product-image-placeholder-{{ ai_gen_id }} {
      width: 80px;
      height: 80px;
    }

    .ai-model-modal__product-select-{{ ai_gen_id }} {
      grid-column: 1 / -1;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-model-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_spacing | times: 0.5 }}px;
    }

    .ai-model-card__content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.75 }}px;
    }
  }
{% endstyle %}

<model-grid-{{ ai_gen_id }} class="ai-model-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-model-grid__container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign look_image_key = 'look_' | append: i | append: '_image'
        assign look_title_key = 'look_' | append: i | append: '_title'
        assign look_price_key = 'look_' | append: i | append: '_price'
        assign look_button_type_key = 'look_' | append: i | append: '_button_type'
        assign look_button_text_key = 'look_' | append: i | append: '_button_text'
        assign look_button_link_key = 'look_' | append: i | append: '_button_link'
        assign product_1_key = 'look_' | append: i | append: '_product_1'
        assign product_2_key = 'look_' | append: i | append: '_product_2'
        assign product_3_key = 'look_' | append: i | append: '_product_3'
        assign product_4_key = 'look_' | append: i | append: '_product_4'

        assign look_image = block.settings[look_image_key]
        assign look_title = block.settings[look_title_key]
        assign look_price = block.settings[look_price_key]
        assign look_button_type = block.settings[look_button_type_key]
        assign look_button_text = block.settings[look_button_text_key]
        assign look_button_link = block.settings[look_button_link_key]
        assign product_1 = block.settings[product_1_key]
        assign product_2 = block.settings[product_2_key]
        assign product_3 = block.settings[product_3_key]
        assign product_4 = block.settings[product_4_key]
      %}

      <div class="ai-model-card-{{ ai_gen_id }}" data-look-index="{{ i }}">
        <div class="ai-model-card__image-wrapper-{{ ai_gen_id }}">
          {% if look_image %}
            <img
              src="{{ look_image | image_url: width: 800 }}"
              alt="{{ look_image.alt | escape }}"
              loading="lazy"
              width="{{ look_image.width }}"
              height="{{ look_image.height }}"
              class="ai-model-card__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-model-card__image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        <div class="ai-model-card__content-{{ ai_gen_id }}">
          {% if look_title != blank %}
            <h3 class="ai-model-card__title-{{ ai_gen_id }}">{{ look_title }}</h3>
          {% endif %}

          {% if look_price != blank %}
            <p class="ai-model-card__price-{{ ai_gen_id }}">{{ look_price }}</p>
          {% endif %}

          {% if look_button_type == 'modal' %}
            <button
              class="ai-model-card__button-{{ ai_gen_id }}"
              data-modal-trigger="{{ i }}"
              aria-label="Shop the look {{ i }}"
            >
              {% if look_button_text != blank %}
                {{ look_button_text }}
              {% else %}
                {{ block.settings.default_button_text }}
              {% endif %}
            </button>
          {% else %}
            <a
              href="{{ look_button_link }}"
              class="ai-model-card__link-{{ ai_gen_id }}"
            >
              {% if look_button_text != blank %}
                {{ look_button_text }}
              {% else %}
                {{ block.settings.default_button_text }}
              {% endif %}
            </a>
          {% endif %}
        </div>
      </div>

      {% if look_button_type == 'modal' %}
        <div class="ai-model-modal-{{ ai_gen_id }}" data-modal="{{ i }}" role="dialog" aria-modal="true">
          <div class="ai-model-modal__content-{{ ai_gen_id }}">
            <button class="ai-model-modal__close-{{ ai_gen_id }}" data-modal-close="{{ i }}" aria-label="Close modal">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>

            <div class="ai-model-modal__header-{{ ai_gen_id }}">
              {% if look_title != blank %}
                <h2 class="ai-model-modal__title-{{ ai_gen_id }}">{{ look_title }}</h2>
              {% endif %}
              <p class="ai-model-modal__subtitle-{{ ai_gen_id }}">{{ block.settings.modal_subtitle }}</p>
            </div>

            {% assign has_products = false %}
            {% if product_1 != blank or product_2 != blank or product_3 != blank or product_4 != blank %}
              {% assign has_products = true %}
            {% endif %}

            {% if has_products %}
              <div class="ai-model-modal__products-{{ ai_gen_id }}">
                {% for j in (1..4) %}
                  {% liquid
                    assign product_key = 'look_' | append: i | append: '_product_' | append: j
                    assign product = block.settings[product_key]
                  %}

                  {% if product != blank %}
                    <div class="ai-model-modal__product-{{ ai_gen_id }}" data-product-id="{{ product.id }}">
                      {% if product.featured_image %}
                        <img
                          src="{{ product.featured_image | image_url: width: 200 }}"
                          alt="{{ product.featured_image.alt | escape }}"
                          class="ai-model-modal__product-image-{{ ai_gen_id }}"
                          loading="lazy"
                        >
                      {% else %}
                        <div class="ai-model-modal__product-image-placeholder-{{ ai_gen_id }}">
                          {{ 'product-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}

                      <div class="ai-model-modal__product-info-{{ ai_gen_id }}">
                        <h4 class="ai-model-modal__product-title-{{ ai_gen_id }}">{{ product.title }}</h4>
                        <p class="ai-model-modal__product-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
                        {% if product.variants.size > 1 %}
                          <p class="ai-model-modal__product-variant-{{ ai_gen_id }}">{{ product.variants.size }} options available</p>
                        {% endif %}
                      </div>

                      {% if product.variants.size > 1 %}
                        <select class="ai-model-modal__product-select-{{ ai_gen_id }}" data-variant-select>
                          {% for variant in product.variants %}
                            <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                              {{ variant.title }} - {{ variant.price | money }}
                              {% unless variant.available %} (Sold out){% endunless %}
                            </option>
                          {% endfor %}
                        </select>
                      {% else %}
                        <input type="hidden" data-variant-select value="{{ product.first_available_variant.id }}">
                      {% endif %}
                    </div>
                  {% endif %}
                {% endfor %}
              </div>

              <button class="ai-model-modal__add-button-{{ ai_gen_id }}" data-add-to-cart="{{ i }}">
                {{ block.settings.add_to_cart_text }}
              </button>
            {% else %}
              <div class="ai-model-modal__empty-{{ ai_gen_id }}">
                <p>No products added to this look yet. Configure products in the theme editor.</p>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</model-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ModelGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.modals = this.querySelectorAll('.ai-model-modal-{{ ai_gen_id }}');
        this.triggers = this.querySelectorAll('[data-modal-trigger]');
        this.closeButtons = this.querySelectorAll('[data-modal-close]');
        this.addToCartButtons = this.querySelectorAll('[data-add-to-cart]');
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.triggers.forEach((trigger) => {
          trigger.addEventListener('click', (e) => {
            const modalId = e.currentTarget.getAttribute('data-modal-trigger');
            this.openModal(modalId);
          });
        });

        this.closeButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            const modalId = e.currentTarget.getAttribute('data-modal-close');
            this.closeModal(modalId);
          });
        });

        this.modals.forEach((modal) => {
          modal.addEventListener('click', (e) => {
            if (e.target === modal) {
              const modalId = modal.getAttribute('data-modal');
              this.closeModal(modalId);
            }
          });
        });

        this.addToCartButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            const modalId = e.currentTarget.getAttribute('data-add-to-cart');
            this.addToCart(modalId, button);
          });
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            this.modals.forEach((modal) => {
              if (modal.classList.contains('active')) {
                const modalId = modal.getAttribute('data-modal');
                this.closeModal(modalId);
              }
            });
          }
        });
      }

      openModal(modalId) {
        const modal = this.querySelector(`[data-modal="${modalId}"]`);
        if (modal) {
          modal.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      }

      closeModal(modalId) {
        const modal = this.querySelector(`[data-modal="${modalId}"]`);
        if (modal) {
          modal.classList.remove('active');
          document.body.style.overflow = '';
        }
      }

      async addToCart(modalId, button) {
        const modal = this.querySelector(`[data-modal="${modalId}"]`);
        const products = modal.querySelectorAll('.ai-model-modal__product-{{ ai_gen_id }}');
        const items = [];

        products.forEach((product) => {
          const variantSelect = product.querySelector('[data-variant-select]');
          if (variantSelect && variantSelect.value) {
            items.push({
              id: variantSelect.value,
              quantity: 1
            });
          }
        });

        if (items.length === 0) {
          return;
        }

        button.disabled = true;
        button.textContent = 'Adding...';

        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ items })
          });

          if (response.ok) {
            button.textContent = 'Added!';
            setTimeout(() => {
              button.textContent = '{{ block.settings.add_to_cart_text }}';
              button.disabled = false;
              this.closeModal(modalId);
              
              if (window.theme && window.theme.cart) {
                window.theme.cart.refresh();
              }
              
              document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', {
                bubbles: true
              }));
            }, 1000);
          } else {
            throw new Error('Failed to add to cart');
          }
        } catch (error) {
          button.textContent = 'Error - Try again';
          button.disabled = false;
          console.error('Error adding to cart:', error);
        }
      }
    }

    customElements.define('model-grid-{{ ai_gen_id }}', ModelGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Model photography grid",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "3 / 4",
          "label": "3:4 (Portrait)"
        },
        {
          "value": "4 / 5",
          "label": "4:5 (Model)"
        },
        {
          "value": "2 / 3",
          "label": "2:3 (Tall)"
        },
        {
          "value": "1 / 1",
          "label": "1:1 (Square)"
        }
      ],
      "default": "3 / 4"
    },
    {
      "type": "range",
      "id": "card_spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Card spacing",
      "default": 20
    },
    {
      "type": "range",
      "id": "content_padding",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Content padding",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "enable_image_zoom",
      "label": "Enable image zoom on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1c1c1c"
    },
    {
      "type": "color",
      "id": "modal_background",
      "label": "Modal background",
      "default": "#ffffff"
