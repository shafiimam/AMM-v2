{% doc %}
  @prompt
    I need a spacer 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spacer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-spacer-{{ ai_gen_id }} {
      height: {{ block.settings.height_mobile }}px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-spacer-{{ ai_gen_id }} {
      height: {{ block.settings.height_desktop }}px;
    }
  }
{% endstyle %}

<div class="ai-spacer-{{ ai_gen_id }}" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Spacer",
  "tag": null,
  "settings": [
    {
      "type": "range",
      "id": "height_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Height on mobile",
      "default": 40
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 0,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Height on desktop",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Spacer"
    }
  ]
}
{% endschema %}
