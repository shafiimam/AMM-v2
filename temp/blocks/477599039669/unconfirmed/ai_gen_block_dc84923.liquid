{% doc %}
  @prompt
    Create a text section with a CTA that links to a modal pop-up.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-modal-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-modal__content-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-text-modal__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing_between_elements }}px 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-text-modal__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing_between_elements }}px 0;
    line-height: 1.6;
  }

  .ai-text-modal__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    cursor: pointer;
    font-size: {{ block.settings.button_text_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    transition: background-color 0.3s ease;
  }

  .ai-text-modal__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-text-modal__overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 9998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-text-modal__overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-text-modal__modal-{{ ai_gen_id }} {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    width: 90%;
    max-width: {{ block.settings.modal_max_width }}px;
    max-height: 90vh;
    overflow-y: auto;
    background-color: {{ block.settings.modal_background }};
    padding: {{ block.settings.modal_padding }}px;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
  }

  .ai-text-modal__modal-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
  }

  .ai-text-modal__modal-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: {{ block.settings.modal_padding }}px;
  }

  .ai-text-modal__modal-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.modal_title_size }}px;
    color: {{ block.settings.modal_text_color }};
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-text-modal__close-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.modal_text_color }};
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .ai-text-modal__close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-text-modal__close-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    stroke-width: 2px;
  }

  .ai-text-modal__modal-content-{{ ai_gen_id }} {
    color: {{ block.settings.modal_text_color }};
    font-size: {{ block.settings.modal_content_size }}px;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-text-modal__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-text-modal__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }

    .ai-text-modal__modal-{{ ai_gen_id }} {
      padding: {{ block.settings.modal_padding | times: 0.7 }}px;
    }

    .ai-text-modal__modal-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.modal_title_size }}px * 0.8);
    }
  }
{% endstyle %}

<text-modal-{{ ai_gen_id }} class="ai-text-modal-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-modal__content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-text-modal__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.text != blank %}
      <div class="ai-text-modal__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
    {% endif %}

    <button
      class="ai-text-modal__button-{{ ai_gen_id }}"
      aria-label="{{ block.settings.button_text }}"
      aria-expanded="false"
    >
      {{ block.settings.button_text }}
    </button>
  </div>

  <div class="ai-text-modal__overlay-{{ ai_gen_id }}" aria-hidden="true"></div>

  <div
    class="ai-text-modal__modal-{{ ai_gen_id }}"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title-{{ ai_gen_id }}"
  >
    <div class="ai-text-modal__modal-header-{{ ai_gen_id }}">
      {% if block.settings.modal_title != blank %}
        <h3 class="ai-text-modal__modal-title-{{ ai_gen_id }}" id="modal-title-{{ ai_gen_id }}">
          {{ block.settings.modal_title }}
        </h3>
      {% endif %}
      <button class="ai-text-modal__close-{{ ai_gen_id }}" aria-label="Close modal">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="ai-text-modal__modal-content-{{ ai_gen_id }}">
      {{ block.settings.modal_content }}
    </div>
  </div>
</text-modal-{{ ai_gen_id }}>

<script>
  (function() {
    class TextModal{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.button = this.querySelector('.ai-text-modal__button-{{ ai_gen_id }}');
        this.modal = this.querySelector('.ai-text-modal__modal-{{ ai_gen_id }}');
        this.overlay = this.querySelector('.ai-text-modal__overlay-{{ ai_gen_id }}');
        this.closeButton = this.querySelector('.ai-text-modal__close-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.button.addEventListener('click', () => this.openModal());
        this.closeButton.addEventListener('click', () => this.closeModal());
        this.overlay.addEventListener('click', () => this.closeModal());

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.modal.classList.contains('active')) {
            this.closeModal();
          }
        });
      }

      openModal() {
        this.modal.classList.add('active');
        this.overlay.classList.add('active');
        this.button.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        this.modal.focus();
      }

      closeModal() {
        this.modal.classList.remove('active');
        this.overlay.classList.remove('active');
        this.button.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        this.button.focus();
      }
    }

    customElements.define('text-modal-{{ ai_gen_id }}', TextModal{{ ai_gen_id }});
  })();
</script>

