{% doc %}
  @prompt
    Create a section for featured brands. I would like the ability to update and re-order the brands featured as well as use an alternate/editorial image. , I would also like to pick from a list of collections 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-brands-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-featured-brands__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-featured-brands__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-featured-brands__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    text-transform: {{ block.settings.heading_text_transform }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}%;
  }

  .ai-featured-brands__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 8px 0 0;
  }

  .ai-featured-brands__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.brands_per_row_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-featured-brands__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.brands_per_row_mobile }}, 1fr);
    }
  }

  .ai-featured-brands__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.item_background_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-featured-brands__item-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_lift | times: 2 }}px {{ block.settings.hover_lift | times: 4 }}px rgba(0, 0, 0, {{ block.settings.hover_shadow_opacity }});
  }

  .ai-featured-brands__link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    text-decoration: none;
  }

  .ai-featured-brands__image-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ai-featured-brands__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    transition: opacity 0.3s ease;
  }

  .ai-featured-brands__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-featured-brands__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-featured-brands__name-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.name_padding }}px;
    background: {{ block.settings.name_background }};
    color: {{ block.settings.name_color }};
    font-size: {{ block.settings.name_size }}px;
    font-weight: {{ block.settings.name_weight }};
    text-align: center;
    text-transform: {{ block.settings.name_text_transform }};
    opacity: {{ block.settings.name_opacity }};
    transition: opacity 0.3s ease;
  }

  {% if block.settings.show_name_on_hover %}
    .ai-featured-brands__name-{{ ai_gen_id }} {
      opacity: 0;
    }

    .ai-featured-brands__item-{{ ai_gen_id }}:hover .ai-featured-brands__name-{{ ai_gen_id }} {
      opacity: {{ block.settings.name_opacity }};
    }
  {% endif %}

  .ai-featured-brands__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 14px;
  }
{% endstyle %}

<featured-brands-{{ ai_gen_id }} class="ai-featured-brands-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-brands__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-featured-brands__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-featured-brands__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <div class="ai-featured-brands__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% liquid
      assign brands_array = ''
      assign has_brands = false

      if block.settings.brand_source == 'collections'
        if block.settings.featured_collections != blank
          assign has_brands = true
          for collection in block.settings.featured_collections
            assign brands_array = brands_array | append: collection.id | append: ','
          endfor
        endif
      else
        for i in (1..12)
          assign brand_enabled_key = 'brand_' | append: i | append: '_enabled'
          if block.settings[brand_enabled_key]
            assign has_brands = true
            break
          endif
        endfor
      endif
    %}

    {% if has_brands %}
      <div class="ai-featured-brands__grid-{{ ai_gen_id }}">
        {% if block.settings.brand_source == 'collections' %}
          {% for collection in block.settings.featured_collections %}
            {% liquid
              assign brand_name = collection.title
              assign brand_url = collection.url
              assign brand_image = collection.image

              if collection.metafields.custom.brand_image != blank
                assign brand_image = collection.metafields.custom.brand_image
              endif
            %}

            <div class="ai-featured-brands__item-{{ ai_gen_id }}">
              <a href="{{ brand_url }}" class="ai-featured-brands__link-{{ ai_gen_id }}" aria-label="{{ brand_name | escape }}">
                <div class="ai-featured-brands__image-wrapper-{{ ai_gen_id }}">
                  {% if brand_image %}
                    <img
                      src="{{ brand_image | image_url: width: 800 }}"
                      alt="{{ brand_name | escape }}"
                      class="ai-featured-brands__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="{{ brand_image.width }}"
                      height="{{ brand_image.height }}"
                    >
                  {% else %}
                    <div class="ai-featured-brands__placeholder-{{ ai_gen_id }}">
                      {{ 'collection-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                {% if block.settings.show_brand_name and brand_name != blank %}
                  <div class="ai-featured-brands__name-{{ ai_gen_id }}">{{ brand_name }}</div>
                {% endif %}
              </a>
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..12) %}
            {% liquid
              assign brand_enabled_key = 'brand_' | append: i | append: '_enabled'
              assign brand_name_key = 'brand_' | append: i | append: '_name'
              assign brand_image_key = 'brand_' | append: i | append: '_image'
              assign brand_url_key = 'brand_' | append: i | append: '_url'
              assign brand_collection_key = 'brand_' | append: i | append: '_collection'

              assign brand_enabled = block.settings[brand_enabled_key]
              assign brand_name = block.settings[brand_name_key]
              assign brand_image = block.settings[brand_image_key]
              assign brand_url = block.settings[brand_url_key]
              assign brand_collection = block.settings[brand_collection_key]

              if brand_collection != blank
                assign brand_url = brand_collection.url
                if brand_name == blank
                  assign brand_name = brand_collection.title
                endif
                if brand_image == blank and brand_collection.image != blank
                  assign brand_image = brand_collection.image
                endif
              endif
            %}

            {% if brand_enabled %}
              <div class="ai-featured-brands__item-{{ ai_gen_id }}">
                {% if brand_url != blank %}
                  <a href="{{ brand_url }}" class="ai-featured-brands__link-{{ ai_gen_id }}" aria-label="{{ brand_name | escape }}">
                {% else %}
                  <div class="ai-featured-brands__link-{{ ai_gen_id }}">
                {% endif %}
                  <div class="ai-featured-brands__image-wrapper-{{ ai_gen_id }}">
                    {% if brand_image %}
                      <img
                        src="{{ brand_image | image_url: width: 800 }}"
                        alt="{{ brand_name | escape }}"
                        class="ai-featured-brands__image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="{{ brand_image.width }}"
                        height="{{ brand_image.height }}"
                      >
                    {% else %}
                      <div class="ai-featured-brands__placeholder-{{ ai_gen_id }}">
                        {{ 'image' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                  {% if block.settings.show_brand_name and brand_name != blank %}
                    <div class="ai-featured-brands__name-{{ ai_gen_id }}">{{ brand_name }}</div>
                  {% endif %}
                {% if brand_url != blank %}
                  </a>
                {% else %}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    {% else %}
      <div class="ai-featured-brands__empty-state-{{ ai_gen_id }}">
        {% if block.settings.brand_source == 'collections' %}
          Select collections to feature as brands
        {% else %}
          Add brands below to showcase your featured partners
        {% endif %}
      </div>
    {% endif %}
  </div>
</featured-brands-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedBrands{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeAccessibility();
      }

      initializeAccessibility() {
        const links = this.querySelectorAll('.ai-featured-brands__link-{{ ai_gen_id }}');
        links.forEach(link => {
          if (!link.getAttribute('aria-label')) {
            const name = link.querySelector('.ai-featured-brands__name-{{ ai_gen_id }}');
            if (name) {
              link.setAttribute('aria-label', name.textContent.trim());
            }
          }
        });
      }
    }

    customElements.define('featured-brands-{{ ai_gen_id }}', FeaturedBrands{{ ai_gen_id }});
  })();
</script>

