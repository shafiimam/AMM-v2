{% doc %}
  @prompt
    Create an image card grid of four across (4-column layout) optimized for model photography.
    
    Layout & Display
    
    Each card should display:
    
    Image or Video at the top (full-width, responsive, model-scale ratio — e.g., 3:4 or 4:5).
    
    Product details below the image/video: product name, price, and a “Shop the Look” button.
    
    Bag icon positioned at the bottom-right of the image/video, not next to the button.
    
    Design & Behavior
    
    Maintain equal spacing and consistent padding between cards.
    
    Cards should stack two across on tablet and one across on mobile.
    
    Use clean typography with minimal overlays — focus remains on the model imagery.
    
    Include hover states for desktop (e.g., light image zoom or button reveal).
    
    The bag icon background (default, hover, and active) should be transparent, ensuring it doesn’t appear white over the image.
    
    Ensure full accessibility and responsive behavior consistent across breakpoints.
    
    Functional Goals
    
    Create a visually cohesive, shoppable grid that blends editorial presentation with e-commerce functionality — enabling the customer to experience the look and purchase seamlessly.
    
    Extended “Shop the Look Grid” Functionality
    
    Each Look Card should support:
    
    A linkable “Shop the Look” button that can navigate to a collection, campaign, or editorial page.
    
    A bag icon that always opens the quick-add modal (AJAX bundle add).
    
    Full accessibility, consistent responsiveness, and control over button/link display options.
    
    Requirements (Per Look Card / Block)
    
    Inputs:
    
    Image or video upload (model media).
    
    Recommended aspect ratio 4:5 (accept 3:4 as well).
    
    Up to 8 assigned products (e.g., jacket, knit, pant, shoe, accessory).
    
    Optional Controls / Toggles:
    
    enable_look → show/hide this Look Card.
    
    enable_shop_link → toggle between link or modal functionality for the “Shop the Look” button.
    
    enable_bag_icon → show/hide bag icon.
    
    button_link_url → if present and enabled, the “Shop the Look” button navigates to this URL.
    
    reorder_looks → ability to manually
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-look-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.card_spacing }}px;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-look-card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .ai-look-card__media-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-look-card__media-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .ai-look-card-{{ ai_gen_id }}:hover .ai-look-card__media-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-look-card__media-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-look-card__media-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-look-card__bag-icon-{{ ai_gen_id }} {
    position: absolute;
    bottom: 16px;
    right: 16px;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: transparent;
    border: 1px solid {{ block.settings.bag_icon_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 2;
  }

  .ai-look-card__bag-icon-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.bag_icon_hover_bg }};
    border-color: {{ block.settings.bag_icon_hover_border }};
    transform: scale(1.1);
  }

  .ai-look-card__bag-icon-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: {{ block.settings.bag_icon_color }};
    fill: none;
    stroke-width: 1.6;
  }

  .ai-look-card__bag-icon-{{ ai_gen_id }}:hover svg {
    stroke: {{ block.settings.bag_icon_hover_color }};
  }

  .ai-look-card__details-{{ ai_gen_id }} {
    padding: {{ block.settings.card_content_padding }}px 0 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-look-card__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.3;
    color: {{ block.settings.text_color }};
    margin: 0;
    text-transform: {{ block.settings.title_transform }};
    letter-spacing: 0.02em;
  }

  .ai-look-card__price-{{ ai_gen_id }} {
    font-family: {{ block.settings.price_font.family }}, {{ block.settings.price_font.fallback_families }};
    font-weight: {{ block.settings.price_font.weight }};
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-look-card__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 1px solid {{ block.settings.button_border_color }};
    text-decoration: none;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_size }}px;
    text-transform: {{ block.settings.button_transform }};
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 4px;
  }

  .ai-look-card__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
    color: {{ block.settings.button_hover_text }};
    border-color: {{ block.settings.button_hover_border }};
  }

  .ai-look-card__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 13px;
    color: #999;
    text-align: center;
    pointer-events: none;
    white-space: nowrap;
  }

  @media screen and (max-width: 989px) {
    .ai-look-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.card_spacing | times: 0.75 }}px;
    }

    .ai-look-card__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-look-card__price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size | times: 0.9 }}px;
    }

    .ai-look-card__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size | times: 0.9 }}px;
      padding: 10px 20px;
    }

    .ai-look-card__bag-icon-{{ ai_gen_id }} {
      width: 44px;
      height: 44px;
      bottom: 12px;
      right: 12px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-look-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_spacing | times: 0.5 }}px;
    }

    .ai-look-card__details-{{ ai_gen_id }} {
      padding: {{ block.settings.card_content_padding | times: 0.75 }}px 0 0;
    }
  }

  .ai-look-modal-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-look-modal-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-look-modal__content-{{ ai_gen_id }} {
    background-color: #ffffff;
    max-width: 600px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    padding: 40px;
  }

  .ai-look-modal__close-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: #1c1c1c;
    z-index: 1;
  }

  .ai-look-modal__close-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 1.6;
  }

  .ai-look-modal__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: 24px;
    margin: 0 0 24px;
    text-transform: {{ block.settings.title_transform }};
  }

  .ai-look-modal__products-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-look-modal__product-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    padding: 16px;
    border: 1px solid #e8e8e8;
  }

  .ai-look-modal__product-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
  }

  .ai-look-modal__product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-look-modal__product-info-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-look-modal__product-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    margin: 0;
  }

  .ai-look-modal__product-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: #666;
  }

  .ai-look-modal__product-link-{{ ai_gen_id }} {
    font-size: 13px;
    text-decoration: underline;
    color: #1c1c1c;
    margin-top: 4px;
  }

  .ai-look-modal__add-all-{{ ai_gen_id }} {
    margin-top: 24px;
    width: 100%;
    padding: 14px 24px;
    background-color: #1c1c1c;
    color: #ffffff;
    border: none;
    cursor: pointer;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
  }

  .ai-look-modal__add-all-{{ ai_gen_id }}:hover {
    background-color: #000000;
  }

  .ai-look-modal__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #999;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-look-modal__content-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-look-modal__product-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-look-modal__product-image-{{ ai_gen_id }} {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
    }
  }
{% endstyle %}

<shop-the-look-grid-{{ ai_gen_id }} class="ai-look-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% for i in (1..8) %}
    {% liquid
      assign look_enabled_key = 'look_' | append: i | append: '_enabled'
      assign look_image_key = 'look_' | append: i | append: '_image'
      assign look_video_key = 'look_' | append: i | append: '_video'
      assign look_title_key = 'look_' | append: i | append: '_title'
      assign look_price_key = 'look_' | append: i | append: '_price'
      assign look_button_text_key = 'look_' | append: i | append: '_button_text'
      assign look_button_link_key = 'look_' | append: i | append: '_button_link'
      assign look_enable_shop_link_key = 'look_' | append: i | append: '_enable_shop_link'
      assign look_enable_bag_key = 'look_' | append: i | append: '_enable_bag_icon'

      assign look_enabled = block.settings[look_enabled_key]
      assign look_image = block.settings[look_image_key]
      assign look_video = block.settings[look_video_key]
      assign look_title = block.settings[look_title_key]
      assign look_price = block.settings[look_price_key]
      assign look_button_text = block.settings[look_button_text_key]
      assign look_button_link = block.settings[look_button_link_key]
      assign look_enable_shop_link = block.settings[look_enable_shop_link_key]
      assign look_enable_bag = block.settings[look_enable_bag_key]

      assign product_1_key = 'look_' | append: i | append: '_product_1'
      assign product_2_key = 'look_' | append: i | append: '_product_2'
      assign product_3_key = 'look_' | append: i | append: '_product_3'
      assign product_4_key = 'look_' | append: i | append: '_product_4'
      assign product_5_key = 'look_' | append: i | append: '_product_5'
      assign product_6_key = 'look_' | append: i | append: '_product_6'
      assign product_7_key = 'look_' | append: i | append: '_product_7'
      assign product_8_key = 'look_' | append: i | append: '_product_8'

      assign product_1 = block.settings[product_1_key]
      assign product_2 = block.settings[product_2_key]
      assign product_3 = block.settings[product_3_key]
      assign product_4 = block.settings[product_4_key]
      assign product_5 = block.settings[product_5_key]
      assign product_6 = block.settings[product_6_key]
      assign product_7 = block.settings[product_7_key]
      assign product_8 = block.settings[product_8_key]

      assign products_array = ''
      if product_1 != blank
        assign products_array = products_array | append: product_1.id | append: ','
      endif
      if product_2 != blank
        assign products_array = products_array | append: product_2.id | append: ','
      endif
      if product_3 != blank
        assign products_array = products_array | append: product_3.id | append: ','
      endif
      if product_4 != blank
        assign products_array = products_array | append: product_4.id | append: ','
      endif
      if product_5 != blank
        assign products_array = products_array | append: product_5.id | append: ','
      endif
      if product_6 != blank
        assign products_array = products_array | append: product_6.id | append: ','
      endif
      if product_7 != blank
        assign products_array = products_array | append: product_7.id | append: ','
      endif
      if product_8 != blank
        assign products_array = products_array | append: product_8.id | append: ','
      endif
    %}

    {% if look_enabled %}
      <div class="ai-look-card-{{ ai_gen_id }}" data-look-index="{{ i }}">
        <div class="ai-look-card__media-wrapper-{{ ai_gen_id }}">
          {% if look_video != blank %}
            <video
              class="ai-look-card__media-{{ ai_gen_id }}"
              src="{{ look_video }}"
              autoplay
              loop
              muted
              playsinline
            ></video>
          {% elsif look_image != blank %}
            <img
              class="ai-look-card__media-{{ ai_gen_id }}"
              src="{{ look_image | image_url: width: 800 }}"
              alt="{{ look_image.alt | escape }}"
              loading="lazy"
              width="{{ look_image.width }}"
              height="{{ look_image.height }}"
            >
          {% else %}
            <div class="ai-look-card__media-placeholder-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
              <div class="ai-look-card__empty-state-{{ ai_gen_id }}">
                Add image or video
              </div>
            </div>
          {% endif %}

          {% if look_enable_bag %}
            <button
              class="ai-look-card__bag-icon-{{ ai_gen_id }}"
              data-bag-trigger="{{ i }}"
              data-products="{{ products_array }}"
              aria-label="Shop this look"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <path d="M16 10a4 4 0 0 1-8 0"></path>
              </svg>
            </button>
          {% endif %}
        </div>

        <div class="ai-look-card__details-{{ ai_gen_id }}">
          {% if look_title != blank %}
            <h3 class="ai-look-card__title-{{ ai_gen_id }}">{{ look_title }}</h3>
          {% endif %}

          {% if look_price != blank %}
            <p class="ai-look-card__price-{{ ai_gen_id }}">{{ look_price }}</p>
          {% endif %}

          {% if look_button_text != blank %}
            {% if look_enable_shop_link and look_button_link != blank %}
              <a href="{{ look_button_link }}" class="ai-look-card__button-{{ ai_gen_id }}">
                {{ look_button_text }}
              </a>
            {% else %}
              <button
                class="ai-look-card__button-{{ ai_gen_id }}"
                data-modal-trigger="{{ i }}"
                data-products="{{ products_array }}"
              >
                {{ look_button_text }}
              </button>
            {% endif %}
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endfor %}
</shop-the-look-grid-{{ ai_gen_id }}>

<div class="ai-look-modal-{{ ai_gen_id }}" data-modal="{{ ai_gen_id }}">
  <div class="ai-look-modal__content-{{ ai_gen_id }}">
    <button class="ai-look-modal__close-{{ ai_gen_id }}" data-modal-close="{{ ai_gen_id }}" aria-label="Close modal">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <h2 class="ai-look-modal__title-{{ ai_gen_id }}">Shop This Look</h2>
    <div class="ai-look-modal__products-{{ ai_gen_id }}" data-products-container="{{ ai_gen_id }}">
      <div class="ai-look-modal__empty-{{ ai_gen_id }}">
        Add products to this look
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    class ShopTheLookGrid{{ai_gen_id}} extends HTMLElement {
      constructor() {
        super();
        this.modal = document.querySelector('[data-modal="{{ ai_gen_id }}"]');
        this.modalContent = this.modal.querySelector('[data-products-container="{{ ai_gen_id }}"]');
        this.closeButton = this.modal.querySelector('[data-modal-close="{{ ai_gen_id }}"]');
        this.currentProducts = [];
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        const modalTriggers = this.querySelectorAll('[data-modal-trigger]');
        const bagTriggers = this.querySelectorAll('[data-bag-trigger]');

        modalTriggers.forEach(trigger => {
          trigger.addEventListener('click', () => {
            const productsData = trigger.getAttribute('data-products');
            this.openModal(productsData);
          });
        });

        bagTriggers.forEach(trigger => {
          trigger.addEventListener('click', () => {
            const productsData = trigger.getAttribute('data-products');
            this.openModal(productsData);
          });
        });

        this.closeButton.addEventListener('click', () => {
          this.closeModal();
        });

        this.modal.addEventListener('click', (e) => {
          if (e.target === this.modal) {
            this.closeModal();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.modal.classList.contains('active')) {
            this.closeModal();
          }
        });
      }

      async openModal(productsData) {
        if (!productsData) {
          this.modalContent.innerHTML = '<div class="ai-look-modal__empty-{{ ai_gen_id }}">No products assigned to this look</div>';
          this.modal.classList.add('active');
          document.body.style.overflow = 'hidden';
          return;
        }

        const productIds = productsData.split(',').filter(id => id);
        
        if (productIds.length === 0) {
          this.modalContent.innerHTML = '<div class="ai-look-modal__empty-{{ ai_gen_id }}">No products assigned to this look</div>';
          this.modal.classList.add('active');
          document.body.style.overflow = 'hidden';
          return;
        }

        this.currentProducts = productIds;
        await this.loadProducts(productIds);
        this.modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      closeModal() {
        this.modal.classList.remove('active');
        document.body.style.overflow = '';
      }

      async loadProducts(productIds) {
        this.modalContent.innerHTML = '<div class="ai-look-modal__empty-{{ ai_gen_id }}">Loading products...</div>';

        try {
          const productPromises = productIds.map(id => 
            fetch(`/products/${id}.js`).then(res => res.json())
          );

          const products = await Promise.all(productPromises);
          this.renderProducts(products);
        } catch (error) {
          this.modalContent.innerHTML = '<div class="ai-look-modal__empty-{{ ai_gen_id }}">Error loading products</div>';
        }
      }

      renderProducts(products) {
        let html = '';

        products.forEach(product => {
          const price = this.formatMoney(product.price);
          const imageUrl = product.featured_image || '';

          html += `
            <div class="ai-look-modal__product-{{ ai_gen_id }}">
              <div class="ai-look-modal__product-image-{{ ai_gen_id }}">
                ${imageUrl ? `<img src="${imageUrl}" alt="${product.title}">` : ''}
              </div>
              <div class="ai-look-modal__product-info-{{ ai_gen_id }}">
                <h4 class="ai-look-modal__product-title-{{ ai_gen_id }}">${product.title}</h4>
                <div class="ai-look-modal__product-price-{{ ai_gen_id }}">${price}</div>
                <a href="${product.url}" class="ai-look-modal__product-link-{{ ai_gen_id }}">View details</a>
              </div>
            </div>
          `;
        });

        html += `
          <button class="ai-look-modal__add-all-{{ ai_gen_id }}" data-add-all="{{ ai_gen_id }}">
            Add All to Bag
          </button>
        `;

        this.modalContent.innerHTML = html;

        const addAllButton = this.modalContent.querySelector('[data-add-all="{{ ai_gen_id }}"]');
        if (addAllButton) {
          addAllButton.addEventListener('click', () => {
            this.addAllToCart(products);
          });
        }
      }

      async addAllToCart(products) {
        const items = products.map(product => ({
          id: product.variants[0].id,
          quantity: 1
        }));

        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ items })
          });

          if (response.ok) {
            window.location.href = '/cart';
          }
        } catch (error) {
          console.error('Error adding products to cart:', error);
        }
      }

      formatMoney(cents) {
        const dollars = (cents / 100).toFixed(2);
        return `$${dollars}`;
      }
    }

    customElements.define('shop-the-look-grid-{{ ai_gen_id }}', ShopTheLookGrid{{ai_gen_id}});
  })();
</script>

{% schema %}
{
  "name": "Shop the look grid",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "card_spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Card spacing",
      "default": 20
    },
