{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
PREDICTIVE SEARCH
----------------------------------------------------------------------------------------------------------------------

This section is rendered by the <predictive-search> component, that renders the content of the search. It is used, for
instance, by the header search.

This component uses the predictive search (if available) or fallback to standard search if nothing is visible.

********************************************
Supported variables
********************************************

Nothing
{%- endcomment -%}

{%- capture blocked_search_list -%}{%- render 'search-blocked-list' -%}{%- endcapture -%}

{%- if predictive_search.performed -%}
  {%- liquid
    assign unblocked_products = 0
    for product in predictive_search.resources.products
      comment
        <locksmith:7c65> Code added automatically by the Locksmith app. Do not modify or remove.
      endcomment
      capture var
        render 'locksmith-variables', scope: 'subject', subject: product, subject_parent: predictive_search.resources, variable: 'transparent'
      endcapture
      if var == "true"
      else
        continue
      endif
      comment
        </locksmith:7c65> End Locksmith code block.
      endcomment
      assign url_path = product.url | split: '?' | first | remove_first: '/' | downcase
      assign url_check = ',' | append: url_path | append: ','
      unless blocked_search_list contains url_check
        assign unblocked_products = unblocked_products | plus: 1
      endunless
    endfor

    assign unblocked_collections = 0
    for collection in predictive_search.resources.collections
      comment
        <locksmith:ee99> Code added automatically by the Locksmith app. Do not modify or remove.
      endcomment
      capture var
        render 'locksmith-variables', scope: 'subject', subject: collection, subject_parent: predictive_search.resources, variable: 'transparent'
      endcapture
      if var == "true"
      else
        continue
      endif
      comment
        </locksmith:ee99> End Locksmith code block.
      endcomment
      assign url_path = collection.url | split: '?' | first | remove_first: '/' | downcase
      assign url_check = ',' | append: url_path | append: ','
      unless blocked_search_list contains url_check
        assign unblocked_collections = unblocked_collections | plus: 1
      endunless
    endfor

    assign unblocked_articles = 0
    for article in predictive_search.resources.articles
      assign url_path = article.url | split: '?' | first | remove_first: '/' | downcase
      assign url_check = ',' | append: url_path | append: ','
      unless blocked_search_list contains url_check
        assign unblocked_articles = unblocked_articles | plus: 1
      endunless
    endfor

    assign unblocked_pages = 0
    for page in predictive_search.resources.pages
      assign url_path = page.url | split: '?' | first | remove_first: '/' | downcase
      assign url_check = ',' | append: url_path | append: ','
      unless blocked_search_list contains url_check
        assign unblocked_pages = unblocked_pages | plus: 1
      endunless
    endfor

    assign results_count = unblocked_products | plus: unblocked_collections | plus: unblocked_articles | plus: unblocked_pages | plus: predictive_search.resources.queries.size
  -%}

  {%- if results_count > 0 -%}
    <div class="predictive-search__results {% if predictive_search.resources.queries.size > 0 %}predictive-search__results--with-suggestions{% endif %}">
      {%- if predictive_search.resources.queries.size > 0 -%}
        <div class="predictive-search__resource-item">
          <div class="v-stack gap-6 sm:gap-8">
            <p class="predictive-search__category h6 text-subdued">{{ 'search.general.suggestions' | t }}</p>

            <div class="predictive-search__suggestions scroll-area bleed md:unbleed">
              {%- render 'predictive-search-result-item' for predictive_search.resources.queries as query, type: 'query' -%}
            </div>
          </div>
        </div>
      {%- endif -%}

      <x-tabs class="predictive-search__tabs content-tabs">
        <template shadowrootmode="open">
          <style>
            .scrollable::-webkit-scrollbar {
              display: none;
            }
          </style>

          <div part="tab-list-scrollable" class="scrollable">
            <slot role="tablist" part="tab-list" name="title"></slot>
          </div>

          <slot part="tab-panels" name="content"></slot>
        </template>

        {%- if unblocked_products > 0 -%}
          <button type="button" class="h6" role="tab" slot="title">{{ 'search.general.products' | t }}</button>

          <div class="predictive-search__resource-item" role="tabpanel" slot="content" {% cycle 'result_tab': '', 'hidden', 'hidden', 'hidden' %}>
            {%- if predictive_search.resources.queries.size > 0 -%}
              {%- assign products_count = 4 -%}
            {%- else -%}
              {%- assign products_count = 5 -%}
            {%- endif -%}

            <div class="v-stack gap-8 sm:gap-12">
              <div class="predictive-search__products" style="--product-list-items-per-row: {{ products_count }}">
                {%- assign predictive_products_shown = 0 -%}
                {%- for product in predictive_search.resources.products -%}
                  {%- comment %}<locksmith:9795>{% endcomment -%}
                    {%- capture var %}{% render 'locksmith-variables', scope: 'subject', subject: product, subject_parent: predictive_search.resources, variable: 'transparent' %}{% endcapture %}{% if var == "true" %}{% else %}{% continue %}{% endif -%}
                  {%- comment %}</locksmith:9795>{% endcomment -%}
                  {%- if predictive_products_shown >= products_count -%}{%- break -%}{%- endif -%}
                  {%- assign url_path = product.url | split: '?' | first | remove_first: '/' | downcase -%}
                  {%- assign url_check = ',' | append: url_path | append: ',' -%}
                  {%- if blocked_search_list contains url_check -%}{%- continue -%}{%- endif -%}
                  {%- render 'predictive-search-result-item', product: product, type: 'product' -%}
                  {%- assign predictive_products_shown = predictive_products_shown | plus: 1 -%}
                {%- endfor -%}
              </div>

              <div class="justify-self-start sm:justify-self-center">
                {%- assign button_content = 'search.general.view_all_results' | t -%}
                {%- render 'button', type: 'submit', form: 'predictive-search-form', content: button_content -%}
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- if unblocked_collections > 0 -%}
          <button type="button" class="h6" role="tab" slot="title">{{ 'search.general.collections' | t }}</button>

          <div class="predictive-search__resource-item" role="tabpanel" slot="content" {% cycle 'result_tab': '', 'hidden', 'hidden', 'hidden' %}>
            {%- if predictive_search.resources.queries.size > 0 -%}
              {%- assign collections_count = 4 -%}
            {%- else -%}
              {%- assign collections_count = 5 -%}
            {%- endif -%}

            <div class="predictive-search__collections" style="--collection-list-items-per-row: {{ collections_count }}">
              {%- assign predictive_collections_shown = 0 -%}
              {%- for collection in predictive_search.resources.collections -%}
                {%- comment %}<locksmith:810f>{% endcomment -%}
                  {%- capture var %}{% render 'locksmith-variables', scope: 'subject', subject: collection, subject_parent: predictive_search.resources, variable: 'transparent' %}{% endcapture %}{% if var == "true" %}{% else %}{% continue %}{% endif -%}
                {%- comment %}</locksmith:810f>{% endcomment -%}
                {%- if predictive_collections_shown >= collections_count -%}{%- break -%}{%- endif -%}
                {%- assign url_path = collection.url | split: '?' | first | remove_first: '/' | downcase -%}
                {%- assign url_check = ',' | append: url_path | append: ',' -%}
                {%- if blocked_search_list contains url_check -%}{%- continue -%}{%- endif -%}
                {%- render 'predictive-search-result-item', collection: collection, type: 'collection' -%}
                {%- assign predictive_collections_shown = predictive_collections_shown | plus: 1 -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- if unblocked_articles > 0 -%}
          <button type="button" class="h6" role="tab" slot="title">{{ 'search.general.posts' | t }}</button>

          <div class="predictive-search__resource-item" role="tabpanel" slot="content" {% cycle 'result_tab': '', 'hidden', 'hidden', 'hidden' %}>
            {%- if predictive_search.resources.queries.size > 0 -%}
              {%- assign articles_count = 3 -%}
            {%- else -%}
              {%- assign articles_count = 4 -%}
            {%- endif -%}

            <div class="predictive-search__blog-posts" style="--blog-post-list-items-per-row: {{ articles_count }}">
              {%- assign predictive_articles_shown = 0 -%}
              {%- for article in predictive_search.resources.articles -%}
                {%- if predictive_articles_shown >= articles_count -%}{%- break -%}{%- endif -%}
                {%- assign url_path = article.url | split: '?' | first | remove_first: '/' | downcase -%}
                {%- assign url_check = ',' | append: url_path | append: ',' -%}
                {%- if blocked_search_list contains url_check -%}{%- continue -%}{%- endif -%}
                {%- render 'predictive-search-result-item', article: article, type: 'article' -%}
                {%- assign predictive_articles_shown = predictive_articles_shown | plus: 1 -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- if unblocked_pages > 0 -%}
          <button type="button" class="h6" role="tab" slot="title">{{ 'search.general.pages' | t }}</button>

          <div class="predictive-search__resource-item" role="tabpanel" slot="content" {% cycle 'result_tab': '', 'hidden', 'hidden', 'hidden' %}>
            <div class="predictive-search__pages v-stack justify-items-start gap-3">
              {%- for page in predictive_search.resources.pages -%}
                {%- assign url_path = page.url | split: '?' | first | remove_first: '/' | downcase -%}
                {%- assign url_check = ',' | append: url_path | append: ',' -%}
                {%- if blocked_search_list contains url_check -%}{%- continue -%}{%- endif -%}
                {%- render 'predictive-search-result-item', page: page, type: 'page' -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </x-tabs>
    </div>
  {%- else -%}
    <p class="predictive-search__no-results text-lg">{{ 'search.general.no_results' | t: terms: search.terms }}</p>
  {%- endif -%}
{%- elsif search.performed -%}
  {%- liquid
    assign product_results = search.results | where: 'object_type', 'product'
    assign article_results = search.results | where: 'object_type', 'article'
    assign page_results = search.results | where: 'object_type', 'page'

    assign unblocked_products = 0
    for product in product_results
      comment
        <locksmith:4a28> Code added automatically by the Locksmith app. Do not modify or remove.
      endcomment
      capture var
        render 'locksmith-variables', scope: 'subject', subject: product, variable: 'transparent'
      endcapture
      if var == "true"
      else
        continue
      endif
      comment
        </locksmith:4a28> End Locksmith code block.
      endcomment
      assign url_path = product.url | split: '?' | first | remove_first: '/' | downcase
      assign url_check = ',' | append: url_path | append: ','
      unless blocked_search_list contains url_check
        assign unblocked_products = unblocked_products | plus: 1
      endunless
    endfor

    assign unblocked_articles = 0
    for article in article_results
      comment
        <locksmith:89e8> Code added automatically by the Locksmith app. Do not modify or remove.
      endcomment
      capture var
        render 'locksmith-variables', scope: 'subject', subject: article, variable: 'transparent'
      endcapture
      if var == "true"
      else
        continue
      endif
      comment
        </locksmith:89e8> End Locksmith code block.
      endcomment
      assign url_path = article.url | split: '?' | first | remove_first: '/' | downcase
      assign url_check = ',' | append: url_path | append: ','
      unless blocked_search_list contains url_check
        assign unblocked_articles = unblocked_articles | plus: 1
      endunless
    endfor

    assign unblocked_pages = 0
    for page in page_results
      comment
        <locksmith:49dc> Code added automatically by the Locksmith app. Do not modify or remove.
      endcomment
      capture var
        render 'locksmith-variables', scope: 'subject', subject: page, variable: 'transparent'
      endcapture
      if var == "true"
      else
        continue
      endif
      comment
        </locksmith:49dc> End Locksmith code block.
      endcomment
      assign url_path = page.url | split: '?' | first | remove_first: '/' | downcase
      assign url_check = ',' | append: url_path | append: ','
      unless blocked_search_list contains url_check
        assign unblocked_pages = unblocked_pages | plus: 1
      endunless
    endfor

    assign filtered_results_count = unblocked_products | plus: unblocked_articles | plus: unblocked_pages
  -%}

  {%- if filtered_results_count > 0 -%}
    <div class="predictive-search__results">
      <x-tabs class="predictive-search__tabs content-tabs">
        <template shadowrootmode="open">
          <style>
            .scrollable::-webkit-scrollbar {
              display: none;
            }
          </style>

          <div part="tab-list-scrollable" class="scrollable">
            <slot role="tablist" part="tab-list" name="title"></slot>
          </div>

          <slot part="tab-panels" name="content"></slot>
        </template>

        {%- if unblocked_products > 0 -%}
          <button type="button" class="h6" role="tab" slot="title">{{ 'search.general.products' | t }}</button>

          <div class="predictive-search__resource-item" role="tabpanel" slot="content" {% cycle 'result_tab': '', 'hidden', 'hidden', 'hidden' %}>
            {%- assign products_count = 5 -%}

            <div class="v-stack gap-8 sm:gap-12">
              <div class="predictive-search__products" style="--product-list-items-per-row: {{ products_count }}">
                {%- assign search_products_shown = 0 -%}
                {%- for product in product_results -%}
                  {%- comment %}<locksmith:892b>{% endcomment -%}
                    {%- capture var %}{% render 'locksmith-variables', scope: 'subject', subject: product, variable: 'transparent' %}{% endcapture %}{% if var == "true" %}{% else %}{% continue %}{% endif -%}
                  {%- comment %}</locksmith:892b>{% endcomment -%}
                  {%- if search_products_shown >= products_count -%}{%- break -%}{%- endif -%}
                  {%- assign url_path = product.url | split: '?' | first | remove_first: '/' | downcase -%}
                  {%- assign url_check = ',' | append: url_path | append: ',' -%}
                  {%- if blocked_search_list contains url_check -%}{%- continue -%}{%- endif -%}
                  {%- render 'predictive-search-result-item', product: product, type: 'product' -%}
                  {%- assign search_products_shown = search_products_shown | plus: 1 -%}
                {%- endfor -%}
              </div>

              <div class="justify-self-start sm:justify-self-center">
                {%- assign button_content = 'search.general.view_all_results' | t -%}
                {%- render 'button', type: 'submit', form: 'predictive-search-form', content: button_content -%}
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- if unblocked_articles > 0 -%}
          <button type="button" class="h6" role="tab" slot="title">{{ 'search.general.posts' | t }}</button>

          <div class="predictive-search__resource-item" role="tabpanel" slot="content" {% cycle 'result_tab': '', 'hidden', 'hidden', 'hidden' %}>
            {%- assign articles_count = 4 -%}

            <div class="predictive-search__blog-posts" style="--blog-post-list-items-per-row: {{ articles_count }}">
              {%- assign search_articles_shown = 0 -%}
              {%- for article in article_results -%}
                {%- comment %}<locksmith:3fda>{% endcomment -%}
                  {%- capture var %}{% render 'locksmith-variables', scope: 'subject', subject: article, variable: 'transparent' %}{% endcapture %}{% if var == "true" %}{% else %}{% continue %}{% endif -%}
                {%- comment %}</locksmith:3fda>{% endcomment -%}
                {%- if search_articles_shown >= articles_count -%}{%- break -%}{%- endif -%}
                {%- assign url_path = article.url | split: '?' | first | remove_first: '/' | downcase -%}
                {%- assign url_check = ',' | append: url_path | append: ',' -%}
                {%- if blocked_search_list contains url_check -%}{%- continue -%}{%- endif -%}
                {%- render 'predictive-search-result-item', article: article, type: 'article' -%}
                {%- assign search_articles_shown = search_articles_shown | plus: 1 -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- if unblocked_pages > 0 -%}
          <button type="button" class="h6" role="tab" slot="title">{{ 'search.general.pages' | t }}</button>

          <div class="predictive-search__resource-item" role="tabpanel" slot="content" {% cycle 'result_tab': '', 'hidden', 'hidden', 'hidden' %}>
            <div class="predictive-search__pages v-stack justify-items-start gap-3">
              {%- for page in page_results -%}
                {%- comment %}<locksmith:1288>{% endcomment -%}
                  {%- capture var %}{% render 'locksmith-variables', scope: 'subject', subject: page, variable: 'transparent' %}{% endcapture %}{% if var == "true" %}{% else %}{% continue %}{% endif -%}
                {%- comment %}</locksmith:1288>{% endcomment -%}
                {%- assign url_path = page.url | split: '?' | first | remove_first: '/' | downcase -%}
                {%- assign url_check = ',' | append: url_path | append: ',' -%}
                {%- if blocked_search_list contains url_check -%}{%- continue -%}{%- endif -%}
                {%- render 'predictive-search-result-item', page: page, type: 'page' -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </x-tabs>
    </div>
  {%- else -%}
    <p class="predictive-search__no-results text-lg">{{ 'search.general.no_results' | t: terms: search.terms }}</p>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "t:sections.predictive_search.predictive_search"
}
{% endschema %}