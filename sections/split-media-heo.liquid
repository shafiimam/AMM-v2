        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "height",
      "options": [
        {
          "value": "auto",
          "label": "auto"
        },
        {
          "value": "small",
          "label": "small"
        },
        {
          "value": "medium",
          "label": "medium"
        },
        {
          "value": "large",
          "label": "large"
        },
        {
          "value": "full-screen",
          "label": "full_screen"
        },
        {
          "value": "custom",
